# 环境变量配置示例
# 说明：复制此文件为 .env，并填入实际的 API Key

# ============ Free API 配置 ============
# 命名规则：FREE{编号}_API_KEY
# 例如：free1 -> FREE1_API_KEY, free2 -> FREE2_API_KEY

# Free1 API Key (OpenRouter)
FREE1_API_KEY=your_openrouter_api_key_here

# Free2 API Key
FREE2_API_KEY=your_free2_api_key_here

# Free3 API Key
FREE3_API_KEY=your_free3_api_key_here

# ... 依此类推

# ============ 代理配置（可选） ============
# 如果使用代理，取消以下行的注释并配置代理地址
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ============ multi_free_api_proxy 配置（可选） ============
# 服务端口
# PORT=5000

# 最大并发请求数
# MAX_CONCURRENT_REQUESTS=5

# 缓存目录
# CACHE_DIR=./cache
